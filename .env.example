# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE CONFIGURATION (For programmatically initializing Firebase if google-services.json is not present)
FIREBASE_API_KEY=placeholder_firebase_api_key
FIREBASE_PROJECT_ID=placeholder_firebase_project_id
FIREBASE_APP_ID=placeholder_firebase_app_id
